<section id="overview" class="site-hero text-white py-5">
  <div class="container py-lg-4">
    <div class="row align-items-center g-5">
      <div class="col-lg-7">
        <span class="badge text-bg-light text-uppercase fw-semibold mb-3">Udemy Course</span>
        <h1 class="display-5 fw-bold mb-3"><%= title %></h1>
        <p class="lead text-white-50 mb-4"><%= tagline %></p>

        <div class="d-flex flex-wrap align-items-center gap-3 mb-4">
          <span class="hero-rating fw-semibold"><%= rating %> &#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span class="text-white-50">Created by <%= instructor %></span>
        </div>

        <div class="d-flex flex-wrap gap-3">
          <a class="btn btn-brand btn-lg" href="<%= cta_url %>" target="_blank" rel="noopener"><%= cta_text %></a>
          <a class="btn btn-outline-light btn-lg" href="<%= cta_url %>" target="_blank" rel="noopener">Preview the course</a>
        </div>
      </div>

      <div class="col-lg-5">
        <div class="card shadow-lg border-0">
          <% if image&.attached? %>
            <%= image_tag image, class: "card-img-top", style: "max-height: 180px; object-fit: cover;" %>
          <% end %>
          <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">Course at a glance</h2>
            <ul class="list-unstyled mb-4">
              <% stats.each do |stat| %>
                <li class="d-flex justify-content-between border-bottom py-2">
                  <span class="text-body-secondary"><%= stat.label %></span>
                  <span class="fw-semibold"><%= stat.value %></span>
                </li>
              <% end %>
            </ul>
            <a class="btn btn-brand w-100" href="<%= cta_url %>" target="_blank" rel="noopener"><%= cta_text %></a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
