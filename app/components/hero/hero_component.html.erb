<section id="overview" class="site-hero section">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <%= render Badge::BadgeComponent.new(label: "Featured on Udemy") %>
        <h1 class="heading-display heading-display-xl text-accent mt-3 mb-3"><%= title %></h1>
        <p class="lead-copy measure mb-4"><%= tagline %></p>

        <div class="d-flex flex-wrap align-items-center gap-3 mb-4">
          <span class="hero-rating fw-semibold"><%= rating %> &#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span class="text-body-secondary">Created by <%= instructor %></span>
        </div>

        <div class="d-flex flex-wrap gap-3">
          <a class="btn btn-brand btn-lg px-4" href="<%= cta_url %>" target="_blank" rel="noopener"><%= cta_text %></a>
          <a class="btn btn-white btn-lg px-4" href="<%= cta_url %>" target="_blank" rel="noopener">Preview the course</a>
        </div>

        <div class="hero-stats d-flex flex-wrap mt-4 pt-2">
          <% stats.each do |stat| %>
            <div class="hero-stat">
              <div class="eyebrow mb-1"><%= stat.label %></div>
              <div class="h5 fw-bold mb-0"><%= stat.value %></div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="col-lg-6">
        <%# Course-preview thumbnail. Clicking will open a video modal (wired in a
            follow-up); this story is layout only. %>
        <button type="button" class="hero-preview" aria-label="Play the course preview">
          <% if image&.attached? %>
            <%= image_tag image, alt: "Course preview", class: "hero-preview-img" %>
          <% else %>
            <%= image_tag "ruby-chrome.png", alt: "Ruby on Rails 8 and Hotwire course preview", class: "hero-preview-img" %>
          <% end %>
          <span class="hero-preview-play" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
          </span>
          <span class="hero-preview-label">Preview this course</span>
        </button>
      </div>
    </div>
  </div>
</section>
