<section id="faq" class="section bg-body-tertiary">
  <div class="container">
    <%= render Heading::SectionHeadingComponent.new(eyebrow: "FAQ", title: "Frequently asked questions") %>

    <div class="accordion faq-accordion mt-2" id="faqAccordion">
      <% items.each_with_index do |item, index| %>
        <div class="accordion-item">
          <h3 class="accordion-header">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                    data-bs-target="#faq<%= index %>" aria-expanded="false" aria-controls="faq<%= index %>">
              <%= item.question %>
            </button>
          </h3>
          <div id="faq<%= index %>" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
            <div class="accordion-body rich-text-content"><%= helpers.rich_text(item.answer) %></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
