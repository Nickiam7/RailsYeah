<section id="curriculum" class="section bg-body-tertiary">
  <div class="container">
    <div class="d-flex justify-content-between align-items-end flex-wrap gap-2">
      <%= render Heading::SectionHeadingComponent.new(eyebrow: "Curriculum", title: "Course content") %>
      <span class="fw-semibold text-body-secondary"><%= totals %></span>
    </div>

    <div class="accordion curriculum-accordion mt-2">
      <% sections.each_with_index do |section, i| %>
        <div class="accordion-item">
          <h3 class="accordion-header">
            <button class="accordion-button<%= " collapsed" unless i.zero? %>" type="button"
                    data-bs-toggle="collapse" data-bs-target="#curriculum-section-<%= i %>"
                    aria-expanded="<%= i.zero? %>" aria-controls="curriculum-section-<%= i %>">
              <span class="fw-semibold"><%= section.title %></span>
              <span class="curriculum-meta ms-auto me-3 text-body-secondary small text-nowrap"><%= meta_for(section) %></span>
            </button>
          </h3>
          <div id="curriculum-section-<%= i %>" class="accordion-collapse collapse<%= " show" if i.zero? %>">
            <div class="accordion-body p-0">
              <% if section.lectures.any? %>
                <ul class="list-unstyled mb-0">
                  <% section.lectures.each do |lecture| %>
                    <li class="curriculum-lecture d-flex align-items-center gap-3">
                      <span class="curriculum-lecture-icon" aria-hidden="true"><%= lecture_icon(lecture) %></span>
                      <span class="curriculum-lecture-title"><%= lecture.title %></span>
                      <% if lecture.preview? %>
                        <button type="button" class="curriculum-lecture-preview"
                                data-bs-toggle="modal" data-bs-target="#videoModal"
                                data-video-url="<%= preview_url_for(lecture) %>">Preview</button>
                      <% end %>
                      <span class="ms-auto text-body-secondary small text-nowrap"><%= lecture.duration %></span>
                    </li>
                  <% end %>
                </ul>
              <% else %>
                <p class="text-body-secondary small mb-0 px-3 py-3">Lectures coming soon.</p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
