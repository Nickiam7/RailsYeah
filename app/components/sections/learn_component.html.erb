<section id="learn" class="section">
  <div class="container">
    <%= render Heading::SectionHeadingComponent.new(eyebrow: "Course outcomes", title: "What you'll learn") %>

    <div class="row g-5 mt-2">
      <div class="col-lg-5 d-flex flex-column">
        <ul class="list-unstyled mb-0 d-flex flex-column flex-grow-1 justify-content-between gap-4">
          <% objectives.each do |objective| %>
            <li class="d-flex gap-3 align-items-start">
              <span class="check-badge flex-shrink-0" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 8.5l3.5 3.5L13 4" />
                </svg>
              </span>
              <span class="lead mb-0"><%= objective.description %></span>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="col-lg-7">
        <div class="code-editor-frame">
          <%= render Code::EditorComponent.new(files: code_cards) %>
        </div>
        <p class="d-flex align-items-center justify-content-center gap-2 small text-body-secondary mt-3 mb-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-code-slash" viewBox="0 0 16 16">
            <path d="M10.478 1.647a.5.5 0 1 0-.956-.294l-4 13a.5.5 0 0 0 .956.294zM4.854 4.146a.5.5 0 0 1 0 .708L1.707 8l3.147 3.146a.5.5 0 0 1-.708.708l-3.5-3.5a.5.5 0 0 1 0-.708l3.5-3.5a.5.5 0 0 1 .708 0m6.292 0a.5.5 0 0 0 0 .708L14.293 8l-3.147 3.146a.5.5 0 0 0 .708.708l3.5-3.5a.5.5 0 0 0 0-.708l-3.5-3.5a.5.5 0 0 0-.708 0"/>
          </svg>
          Real code, straight from the course.
        </p>
      </div>
    </div>
  </div>
</section>
