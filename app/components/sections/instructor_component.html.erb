<section id="instructor" class="py-5">
  <div class="container">
    <h2 class="h3 fw-bold mb-4">Your instructor</h2>
    <div class="d-flex flex-column flex-sm-row gap-3 align-items-sm-start">
      <% if instructor.avatar.attached? %>
        <%= image_tag instructor.avatar, class: "rounded-circle flex-shrink-0", style: "height: 96px; width: 96px; object-fit: cover;" %>
      <% end %>
      <div>
        <p class="h5 fw-bold mb-1"><%= instructor.name %></p>
        <% if instructor.headline.present? %>
          <p class="text-body-secondary"><%= instructor.headline %></p>
        <% end %>
        <% if instructor.bio.present? %>
          <p class="mb-0" style="max-width: 48rem;"><%= instructor.bio %></p>
        <% end %>
      </div>
    </div>
  </div>
</section>
