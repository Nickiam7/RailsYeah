<section id="instructor" class="section">
  <div class="container">
    <%= render Heading::SectionHeadingComponent.new(eyebrow: "Instructor", title: "Meet your instructor") %>

    <div class="row g-5 mt-2 align-items-center">
      <div class="col-lg-5">
        <div class="d-flex flex-column flex-sm-row align-items-sm-center gap-4">
          <div class="flex-shrink-0">
            <% if instructor.avatar.attached? %>
              <%= image_tag instructor.avatar, alt: instructor.name, class: "instructor-avatar rounded-circle" %>
            <% else %>
              <span class="instructor-avatar instructor-avatar-placeholder rounded-circle d-inline-flex align-items-center justify-content-center" aria-hidden="true">
                <%= instructor.name.to_s.first %>
              </span>
            <% end %>
          </div>

          <div>
            <p class="h4 fw-bold mb-1"><%= instructor.name %></p>
            <% if instructor.headline.present? %>
              <p class="text-accent fw-semibold mb-3"><%= instructor.headline %></p>
            <% end %>
            <% if instructor.bio.present? %>
              <div class="rich-text-content mb-0"><%= helpers.rich_text(instructor.bio) %></div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="col-lg-7">
        <%= render Instructor::TestimonialsComponent.new %>
      </div>
    </div>
  </div>
</section>
