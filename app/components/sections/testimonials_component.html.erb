<section id="reviews" class="section">
  <div class="container">
    <%= render Heading::SectionHeadingComponent.new(eyebrow: "Reviews", title: "What students say") %>

    <div class="row g-4 mt-2">
      <% testimonials.each do |testimonial| %>
        <div class="col-md-4">
          <div class="card testimonial-card h-100">
            <div class="card-body d-flex flex-column">
              <% if stars(testimonial.rating) %>
                <div class="star-rating mb-3" aria-label="<%= testimonial.rating %> out of 5"><%= stars(testimonial.rating) %></div>
              <% end %>
              <p class="testimonial-quote flex-grow-1">&ldquo;<%= testimonial.quote %>&rdquo;</p>
              <div class="d-flex align-items-center gap-3 mt-2">
                <% if testimonial.avatar.attached? %>
                  <%= image_tag testimonial.avatar, alt: testimonial.name,
                        class: "rounded-circle flex-shrink-0", style: "height: 44px; width: 44px; object-fit: cover;" %>
                <% else %>
                  <span class="testimonial-initial flex-shrink-0" aria-hidden="true"><%= testimonial.name.to_s.first %></span>
                <% end %>
                <div>
                  <p class="mb-0 fw-semibold"><%= testimonial.name %></p>
                  <% if testimonial.role.present? %>
                    <p class="small text-body-secondary mb-0"><%= testimonial.role %></p>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
