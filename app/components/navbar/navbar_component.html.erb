<nav class="navbar navbar-expand-lg site-navbar sticky-top" data-bs-theme="dark">
  <div class="container">
    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
      <svg class="site-navbar__mark" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6 2h12l4 6-10 14L2 8z" />
      </svg>
      <%= brand %>
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
            data-bs-target="#primaryNav" aria-controls="primaryNav"
            aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="primaryNav">
      <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
        <% links.each do |link| %>
          <li class="nav-item">
            <a class="nav-link" href="<%= link.href %>"><%= link.label %></a>
          </li>
        <% end %>
      </ul>
      <% if signed_in %>
        <%= link_to "Sign out", destroy_user_session_path,
              class: "btn btn-outline-light ms-lg-3 mt-2 mt-lg-0", data: { turbo_method: :delete } %>
        <ul class="navbar-nav">
          <li class="nav-item">
            <%= link_to( "Admin", admin_path, class: "nav-link") if Rails.env.development? %>
          </li>
        </ul>
      <% else %>
        <a class="btn btn-brand ms-lg-3 mt-2 mt-lg-0" href="<%= cta_url %>" target="_blank" rel="noopener"><%= cta_text %></a>
        <ul class="navbar-nav">
          <li class="nav-item">
            <%= link_to( "Login", new_user_session_path, class: "ms-3 nav-link text-light") if Rails.env.development? %>
          </li>
        </ul>
      <% end %>
    </div>
  </div>
</nav>
