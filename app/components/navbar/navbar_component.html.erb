<nav class="navbar navbar-expand-lg site-navbar sticky-top" data-bs-theme="light"
     data-controller="navbar" data-navbar-threshold-value="50"
     data-navbar-scrolled-class="site-navbar--scrolled">
  <div class="container">
    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
      <svg class="site-navbar__mark" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6 2h12l4 6-10 14L2 8z" />
      </svg>
      <%= brand %>
    </a>

    <button class="navbar-toggler border-0 focus-ring" type="button" data-bs-toggle="collapse"
            data-bs-target="#primaryNav" aria-controls="primaryNav"
            aria-expanded="false" aria-label="Toggle navigation" style="--bs-focus-ring-x: 0px; --bs-focus-ring-y: 0px; --bs-focus-ring-blur: 5px; --bs-focus-ring-color: rgba(226, 29, 44, 0.5) ">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-list" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5"/>
      </svg>
    </button>

    <div class="collapse navbar-collapse" id="primaryNav">
      <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
        <% links.each do |link| %>
          <li class="nav-item">
            <a class="nav-link px-lg-3" href="<%= link.href %>"><%= link.label %></a>
          </li>
        <% end %>
      </ul>

      <div class="d-flex align-items-center gap-2 ms-lg-3 mt-2 mt-lg-0">
        <% if signed_in %>
          <%= link_to "Sign out", destroy_user_session_path,
                class: "btn btn-outline-secondary", data: { turbo_method: :delete } %>
          <% if Rails.env.development? %>
            <%= link_to "Admin", admin_root_path, class: "nav-link" %>
          <% end %>
        <% else %>
          <a class="btn btn-brand px-3" href="<%= cta_url %>" target="_blank" rel="noopener"><%= cta_text %></a>
          <% if Rails.env.development? %>
            <%= link_to "Login", new_user_session_path, class: "nav-link" %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</nav>
