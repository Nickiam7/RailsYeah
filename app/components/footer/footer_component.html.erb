<footer class="site-footer mt-auto py-5">
  <div class="container">
    <div class="row gy-4">
      <div class="col-lg-5">
        <div class="site-footer__brand h5 fw-bold mb-2"><%= brand %></div>
        <p class="mb-0 small"><%= tagline %></p>
      </div>

      <div class="col-6 col-lg-3">
        <h2 class="h6 text-uppercase text-white-50 mb-3">Course</h2>
        <ul class="list-unstyled mb-0">
          <li class="mb-2"><a href="<%= udemy_url %>" target="_blank" rel="noopener">View on Udemy</a></li>
          <li class="mb-2"><a href="#curriculum">Curriculum</a></li>
          <li class="mb-2"><a href="#reviews">Reviews</a></li>
        </ul>
      </div>

      <div class="col-6 col-lg-4">
        <h2 class="h6 text-uppercase text-white-50 mb-3">Instructor</h2>
        <ul class="list-unstyled mb-0">
          <li class="mb-2"><%= instructor %></li>
          <li class="mb-2"><a href="<%= github_url %>" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
      </div>
    </div>

    <hr class="border-secondary my-4">

    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2 small">
      <span>&copy; <%= year %> <%= instructor %>. All rights reserved.</span>
      <a href="<%= udemy_url %>" target="_blank" rel="noopener">Enroll on Udemy &rarr;</a>
    </div>
  </div>
</footer>
