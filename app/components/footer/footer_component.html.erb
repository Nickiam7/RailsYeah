<footer class="site-footer mt-auto py-5">
  <div class="container">
    <div class="row gy-4">
      <div class="col-lg-5">
        <div class="site-footer__brand d-flex align-items-center gap-2 h5 fw-bold mb-2">
          <svg class="site-footer__mark" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6 2h12l4 6-10 14L2 8z" />
          </svg>
          <%= brand %>
        </div>
        <p class="mb-0 small measure"><%= tagline %></p>
      </div>

      <div class="col-6 col-lg-3">
        <h2 class="footer-heading">Course</h2>
        <ul class="list-unstyled mb-0">
          <li class="mb-2"><a href="<%= udemy_url %>" target="_blank" rel="noopener">View on Udemy</a></li>
          <li class="mb-2"><a href="#curriculum">Curriculum</a></li>
          <li class="mb-2"><a href="#reviews">Reviews</a></li>
        </ul>
      </div>

      <div class="col-6 col-lg-4">
        <h2 class="footer-heading">Instructor</h2>
        <ul class="list-unstyled mb-0">
          <li class="mb-2"><%= instructor %></li>
          <li class="mb-2"><a href="<%= github_url %>" target="_blank" rel="noopener">GitHub</a></li>
          <% if Rails.env.development? && helpers.user_signed_in? %>
          <li>
            <%= link_to "Admin", admin_root_path %>
          </li>
          <li>
            <%= link_to "Sign out", destroy_user_session_path,
                class: "btn btn-outline-secondary", data: { turbo_method: :delete } %>
          </li>
          <% else %>
          <li>
            <%= link_to "Login", new_user_session_path, class: "nav-link" %>
          </li>
          <% end %>
        </ul>
      </div>
    </div>

    <hr class="footer-divider my-4">

    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2 small">
      <span>&copy; <%= year %> <%= instructor %>. All rights reserved.</span>
      <a href="<%= udemy_url %>" target="_blank" rel="noopener">Enroll on Udemy &rarr;</a>
    </div>
  </div>
</footer>
