<div class="modal fade video-modal" id="videoModal" tabindex="-1" aria-hidden="true"
     data-controller="video-modal" data-video-modal-active-class="active"
     data-action="show.bs.modal->video-modal#open hidden.bs.modal->video-modal#stop">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
          <p class="video-modal-eyebrow mb-1">Course Preview</p>
          <h2 class="video-modal-title h5 mb-0"><%= course_title %></h2>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="ratio ratio-16x9">
        <video data-video-modal-target="player" class="rounded w-100 h-100" controls playsinline preload="none"></video>
        <div data-video-modal-target="empty" class="video-modal-empty rounded" hidden>Preview coming soon.</div>
      </div>

      <% if items.any? %>
        <p class="video-modal-list-heading mt-3 mb-2">Free Sample Videos:</p>
        <ul class="video-modal-list list-unstyled mb-0">
          <% items.each do |item| %>
            <li>
              <button type="button" class="video-modal-item" data-video-modal-target="item"
                      data-action="video-modal#select" data-video-url="<%= item.url %>">
                <span class="video-modal-item-icon" aria-hidden="true"><%= Video::ModalComponent::PLAY_ICON %></span>
                <span class="video-modal-item-title"><%= item.title %></span>
                <% if item.duration.present? %>
                  <span class="video-modal-item-duration"><%= item.duration %></span>
                <% end %>
              </button>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>
  </div>
</div>
