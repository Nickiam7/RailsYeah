<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold mb-0">Curriculum</h1>
    <%= link_to "New section", new_admin_curriculum_section_path, class: "btn btn-brand" %>
  </div>

  <div class="card shadow-sm">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr><th>Title</th><th class="text-end">Lectures</th><th>Duration</th><th class="text-end">Position</th><th class="text-end">Actions</th></tr>
      </thead>
      <tbody>
        <% @curriculum_sections.each do |section| %>
          <tr id="<%= dom_id(section) %>">
            <td><%= section.title %></td>
            <td class="text-end"><%= section.lectures_count %></td>
            <td><%= section.duration %></td>
            <td class="text-end"><%= section.position %></td>
            <td class="text-end text-nowrap">
              <%= link_to "Edit", edit_admin_curriculum_section_path(section), class: "btn btn-sm btn-outline-secondary" %>
              <%= link_to "Delete", admin_curriculum_section_path(section), class: "btn btn-sm btn-outline-danger",
                    data: { turbo_method: :delete, turbo_confirm: "Delete this section?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
