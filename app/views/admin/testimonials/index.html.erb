<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold mb-0">Testimonials</h1>
    <%= link_to "New testimonial", new_admin_testimonial_path, class: "btn btn-brand" %>
  </div>

  <div class="card shadow-sm">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr><th>Name</th><th>Role</th><th class="text-end">Rating</th><th>Published</th><th class="text-end">Actions</th></tr>
      </thead>
      <tbody>
        <% @testimonials.each do |testimonial| %>
          <tr id="<%= dom_id(testimonial) %>">
            <td><%= testimonial.name %></td>
            <td><%= testimonial.role %></td>
            <td class="text-end"><%= testimonial.rating %></td>
            <td><%= testimonial.published? ? "Yes" : "No" %></td>
            <td class="text-end text-nowrap">
              <%= link_to "Edit", edit_admin_testimonial_path(testimonial), class: "btn btn-sm btn-outline-secondary" %>
              <%= link_to "Delete", admin_testimonial_path(testimonial), class: "btn btn-sm btn-outline-danger",
                    data: { turbo_method: :delete, turbo_confirm: "Delete this testimonial?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
