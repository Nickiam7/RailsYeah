<%= form_with model: [ :admin, testimonial ] do |form| %>
  <% if testimonial.errors.any? %>
    <div class="alert alert-danger"><%= pluralize(testimonial.errors.count, "error") %> prevented saving.</div>
  <% end %>

  <div class="card shadow-sm">
    <div class="card-body" style="max-width: 42rem;">
      <%= render Admin::FieldComponent.new(form: form, attribute: :name) %>
      <%= render Admin::FieldComponent.new(form: form, attribute: :role) %>
      <%= render Admin::FieldComponent.new(form: form, attribute: :quote, as: :text_area, rows: 4) %>
      <%= render Admin::FieldComponent.new(form: form, attribute: :rating, as: :number_field, min: 1, max: 5) %>
      <%= render Admin::FieldComponent.new(form: form, attribute: :position, as: :number_field) %>
      <%= render Admin::FieldComponent.new(form: form, attribute: :published, as: :check_box) %>

      <% if testimonial.avatar.attached? %>
        <%= image_tag testimonial.avatar, class: "rounded mb-2", style: "height: 64px; width: 64px; object-fit: cover;" %>
      <% end %>
      <%= render Admin::FieldComponent.new(form: form, attribute: :avatar, as: :file_field, label: "Avatar", accept: "image/png,image/jpeg,image/webp") %>

      <div class="d-flex gap-2">
        <%= form.submit "Save", class: "btn btn-brand" %>
        <%= link_to "Cancel", admin_testimonials_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
<% end %>
