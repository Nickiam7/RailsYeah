<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold mb-0">FAQ</h1>
    <%= link_to "New question", new_admin_faq_item_path, class: "btn btn-brand" %>
  </div>

  <div class="card shadow-sm">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr><th>Question</th><th class="text-end">Position</th><th>Published</th><th class="text-end">Actions</th></tr>
      </thead>
      <tbody>
        <% @faq_items.each do |item| %>
          <tr id="<%= dom_id(item) %>">
            <td><%= item.question %></td>
            <td class="text-end"><%= item.position %></td>
            <td><%= item.published? ? "Yes" : "No" %></td>
            <td class="text-end text-nowrap">
              <%= link_to "Edit", edit_admin_faq_item_path(item), class: "btn btn-sm btn-outline-secondary" %>
              <%= link_to "Delete", admin_faq_item_path(item), class: "btn btn-sm btn-outline-danger",
                    data: { turbo_method: :delete, turbo_confirm: "Delete this question?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
