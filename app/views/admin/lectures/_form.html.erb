<%= form_with model: [ :admin, curriculum_section, lecture ] do |form| %>
  <% if lecture.errors.any? %>
    <div class="alert alert-danger"><%= pluralize(lecture.errors.count, "error") %> prevented saving.</div>
  <% end %>

  <div class="card shadow-sm">
    <div class="card-body" style="max-width: 42rem;">
      <%= render Admin::FieldComponent.new(form: form, attribute: :title) %>

      <div class="mb-3">
        <%= form.label :lecture_type, "Type", class: "form-label" %>
        <%= form.select :lecture_type, Lecture::TYPES.map { |t| [ t.capitalize, t ] }, {}, class: "form-select" %>
      </div>

      <%= render Admin::FieldComponent.new(form: form, attribute: :duration) %>
      <%= render Admin::FieldComponent.new(form: form, attribute: :preview, as: :check_box) %>
      <%= render Admin::FieldComponent.new(form: form, attribute: :position, as: :number_field) %>

      <% if lecture.video.attached? %>
        <p class="small text-body-secondary mb-1">Current video: <%= lecture.video.filename %></p>
      <% end %>
      <%= render Admin::FieldComponent.new(form: form, attribute: :video, as: :file_field,
            label: "Preview video", accept: "video/mp4,video/webm,video/ogg,video/quicktime") %>
      <p class="form-text mt-0 mb-3">Shown in the preview modal when “Preview” is enabled. MP4/WebM/Ogg/MOV, up to 200MB.</p>

      <div class="d-flex gap-2">
        <%= form.submit "Save", class: "btn btn-brand" %>
        <%= link_to "Cancel", admin_curriculum_section_lectures_path(curriculum_section), class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
<% end %>
