<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <%= link_to "← Back to Curriculum", admin_curriculum_sections_path, class: "small text-decoration-none" %>
      <h1 class="h3 fw-bold mb-0 mt-1"><%= @curriculum_section.title %> — Lectures</h1>
    </div>
    <%= link_to "New lecture", new_admin_curriculum_section_lecture_path(@curriculum_section), class: "btn btn-brand" %>
  </div>

  <div class="card shadow-sm">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr><th>Title</th><th>Type</th><th>Duration</th><th>Preview</th><th class="text-end">Position</th><th class="text-end">Actions</th></tr>
      </thead>
      <tbody>
        <% @lectures.each do |lecture| %>
          <tr id="<%= dom_id(lecture) %>">
            <td><%= lecture.title %></td>
            <td><%= lecture.lecture_type.capitalize %></td>
            <td><%= lecture.duration %></td>
            <td><% if lecture.preview? %><span class="badge text-bg-secondary">Preview</span><% end %></td>
            <td class="text-end"><%= lecture.position %></td>
            <td class="text-end text-nowrap">
              <%= link_to "Edit", edit_admin_curriculum_section_lecture_path(@curriculum_section, lecture), class: "btn btn-sm btn-outline-secondary" %>
              <%= link_to "Delete", admin_curriculum_section_lecture_path(@curriculum_section, lecture), class: "btn btn-sm btn-outline-danger",
                    data: { turbo_method: :delete, turbo_confirm: "Delete this lecture?" } %>
            </td>
          </tr>
        <% end %>
        <% if @lectures.empty? %>
          <tr><td colspan="6" class="text-body-secondary text-center py-4">No lectures yet. Add the first one.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
