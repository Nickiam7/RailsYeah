<div class="container">
  <h1 class="h3 fw-bold mb-4">Edit instructor</h1>

  <%= form_with model: @instructor, url: admin_instructor_path, method: :patch do |form| %>
    <% if @instructor.errors.any? %>
      <div class="alert alert-danger"><%= pluralize(@instructor.errors.count, "error") %> prevented saving.</div>
    <% end %>

    <div class="card shadow-sm">
      <div class="card-body" style="max-width: 42rem;">
        <%= render Admin::FieldComponent.new(form: form, attribute: :name) %>
        <%= render Admin::FieldComponent.new(form: form, attribute: :headline) %>
        <%= render Admin::FieldComponent.new(form: form, attribute: :bio, as: :text_area, rows: 4) %>

        <% if @instructor.avatar.attached? %>
          <%= image_tag @instructor.avatar, class: "rounded-circle mb-2", style: "height: 96px; width: 96px; object-fit: cover;" %>
        <% end %>
        <%= render Admin::FieldComponent.new(form: form, attribute: :avatar, as: :file_field, label: "Photo", accept: "image/png,image/jpeg,image/webp") %>

        <div class="d-flex gap-2">
          <%= form.submit "Save", class: "btn btn-brand" %>
          <%= link_to "Cancel", admin_root_path, class: "btn btn-outline-secondary" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
