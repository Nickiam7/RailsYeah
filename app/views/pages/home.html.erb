    <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
      Bootstrap JS check (open me)
    </button>
    <ul class="dropdown-menu">
      <li><a class="dropdown-item" href="<%= rails_health_check_path %>">Health check</a></li>
      <li><a class="dropdown-item" href="https://www.udemy.com/course/ruby-on-rails-8-and-hotwire-build-a-password-manager/">Course on Udemy</a></li>
    </ul>
  </div>
</main>
