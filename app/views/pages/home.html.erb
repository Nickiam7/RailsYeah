<%# Placeholder root page — confirms Rails 8 + Bootstrap (no-build) is wired up. %>
<%# Replaced by the real SEO landing shell in a later story. %>
<main class="container py-5">
  <%# Sample ViewComponent rendered in a real view (sidecar: app/components/heading/). %>
  <%= render Heading::HeadingComponent.new(
        title: "Udemy Course Landing Page",
        subtitle: "Rails 8 (no-build) · Postgres · Bootstrap · ViewComponent — foundation is up.",
        align: "center"
      ) %>

  <%# Static styling proof: Bootstrap CSS is applied. %>
  <div class="alert alert-success" role="alert">
    Bootstrap CSS is loaded — if this box is green and rounded, the stylesheet is working.
  </div>

  <%# Interactive proof: the dropdown needs Bootstrap JS + Popper to position/toggle. %>
