<%# Alternate landing page (Udemy/ZTM-style course-card hero). Separate /v2 route;
    the primary landing page (root) is unchanged. Not indexed, to avoid duplicate
    content competing with the real landing page. %>
<% content_for :head do %>
  <meta name="robots" content="noindex, nofollow">
<% end %>

<%= render Hero::CardHeroComponent.new(
      title: @hero&.title || Site::COURSE,
      tagline: @hero&.subtitle || Site::TAGLINE,
      rating: CourseStat.rating_display,
      image: @hero&.image,
      cta_text: @hero&.cta_label || "Enroll on Udemy",
      cta_url: @hero&.cta_url || Site::UDEMY_URL
    ) %>

<%= render Sections::LearnComponent.new(objectives: @objectives) %>
<%= render Sections::CurriculumComponent.new(sections: @curriculum) %>
<%= render Sections::TestimonialsComponent.new(testimonials: @testimonials) %>
<%= render Sections::FaqComponent.new(items: @faqs) %>
<%= render Sections::InstructorComponent.new(instructor: @instructor) %>
